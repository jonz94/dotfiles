{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": " \uf0e7",
          "foreground": "#ffff66",
          "background": "#343A43",
          "type": "root",
          "style": "plain"
        },
        {
          "template": " {{ if .SSHSession }}\udb80\udf18 {{ end }}{{ .UserName }}@{{ .HostName }} ",
          "foreground": "#EACA8D",
          "background": "#343A43",
          "type": "session",
          "style": "powerline"
        },
        {
          "template": " {{.Icon}}  ",
          "foreground": "#343A43",
          "powerline_symbol": "\ue0b0",
          "background": "#DCDFE4",
          "type": "os",
          "style": "powerline"
        },
        {
          "options": {
            "style": "agnoster_full"
          },
          "template": " {{ if eq .Path \"~\" }}\uf015 {{ else }}\uf07c {{ end }} {{ .Path }} ",
          "foreground": "#343A43",
          "powerline_symbol": "\ue0b0",
          "background": "#71BDF2",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "bitbucket_icon": "\uf171  ",
            "branch_ahead_icon": "\uf139 ",
            "branch_behind_icon": "\uf13a ",
            "branch_icon": "\ue0a0 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "git_icon": "\ue702 ",
            "github_icon": "\uf408  ",
            "gitlab_icon": "\uf296  ",
            "tag_icon": "\uf412 "
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }} {{ .BranchStatus }} {{ if .Working.Changed }}\uf044 {{ .Working.String }} {{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} | {{ end }}{{ if .Staging.Changed }}\uf046 {{ .Staging.String }} {{ end }}{{ if gt .StashCount 0 }}\uf01c {{ .StashCount }} {{ end }}{{ if gt .WorktreeCount 0 }}\uf1bb {{ .WorktreeCount }} {{ end }}",
          "foreground": "#343A43",
          "powerline_symbol": "\ue0b0",
          "background": "#A7CB8B",
          "type": "git",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "always_enabled": true,
            "display_exit_code": true
          },
          "template": " {{ if gt .Code 0 }}\uf00d {{ .Meaning }}{{ else }}\uf42e{{ end }} ",
          "type": "status",
          "style": "plain",
          "foreground_templates": ["{{ if gt .Code 0 }}#DCDFE4{{ else }}#A7CB8B{{ end }}"],
          "background_templates": ["{{ if gt .Code 0 }}#E91E63{{ end }}"]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u2588\ue0b0 ",
          "foreground": "#DCDFE4",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ]
}
